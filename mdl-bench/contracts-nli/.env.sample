# Copy this file to `.env` in this directory or in the repository root.
# Existing shell environment variables take precedence over values from `.env`.

# OpenAI-compatible API key used by default:
OPENAI_API_KEY=

# Optional: OpenAI-compatible base URL. For OpenRouter use:
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_BASE_URL=
