@ rfc2822
module email

open std.collections
open std.system.strings

type ProcessingState = LocalPart(unit) | Domain(unit)

func process_email(
    email: List<string>,
    state: ProcessingState
) -> bool:
    case email:
        | List.Cons(symbol, tail):
            if state = ProcessingState.LocalPart() and symbol = "@"
            then process_email(tail, ProcessingState.Domain())
            else if symbol = "@" then false else process_email(tail, state)
        | List.Empty():
            true

func email_is_correct(email: string) -> bool:
    let symbols = to_list(email)
    let state = ProcessingState.LocalPart()
    process_email(symbols, state)

entity email: string

event email_received(email: string)

@ 3.4.1. Addr-spec specification
rule O email_addr_spec_correct: email_is_correct(email) always

rule F malformed_email_received: (email_received(email) and not email_is_correct(email)) eventually

align email to <urn:ietf:rfc:2822:addr-spec> equivalent

fact email = "ti@example.org"
