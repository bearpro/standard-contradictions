module lineq

open std.collections


type Term = {
    coef: int,
    var: int
}

func pwr(a: int, n: int) -> int:
    if n = 0 then 1
    else a * pwr(a, n - 1)

func value(equation: List<Term>) -> int:
    case equation:
        | List.Empty(): 0
        | List.Cons(head, e):
            let pow = 1 + list.len(equation)
            let termValue = (head).coef * pwr((head).var, pow)
            termValue + value(e)

# Helps solver to not iterate over int32^pow
func values_lt_5(equation: List<Term>) -> bool:
    let max = 3
    case equation:
        | List.Empty(): true
        | List.Cons(head, tail):
            (head).coef < max and (head).var < max and values_lt_5(tail)

entity equation: List<Term>

rule O r0: value(equation) = 1 always
rule O r1: list.len(equation) = 2 always
rule O r2: values_lt_5(equation) always

fact case equation:
        | List.Cons({ coef = a }, List.Cons({coef = b}, List.Empty())):
            a = 2 and b = -1
        | _: false

fact (
    list.at(0, equation, Term {coef = 0, var = 0}).coef = -1 and 
    list.at(1, equation, Term {coef = 0, var = 0}).coef = 2
)
