module fixture_pipeline_spec

open std.collections

type InspectionState = Pending(unit) | Accepted(unit) | Rejected(unit)

type Pipe = { length: rat, radius: rat, pressure: int, state: InspectionState }

let inspection_tags = List.Cons(1, List.Cons(2, List.Cons(3, List.Empty())))

func positive_tags(tags: List<int>) -> bool:
    case tags:
        | List.Cons(tag, rest):
            if tag > 0 then positive_tags(rest) else false
        | List.Empty():
            true

func is_accepted(state: InspectionState) -> bool:
    case state:
        | InspectionState.Accepted():
            true
        | InspectionState.Pending():
            false
        | InspectionState.Rejected():
            false

func pipe_ok(pipe: Pipe) -> bool:
    let geometry_ok = pipe.length > 0 and pipe.radius > 0
    let pressure_ok = if pipe.pressure > 0 then true else false
    geometry_ok and pressure_ok and positive_tags(inspection_tags) and is_accepted(pipe.state)

entity pipe: Pipe

event inspected(length: rat)
event pressure_changed(pressure: int)

rule O pipe_geometry: (pipe.length > 0 and pipe.radius > 0) always
rule O pipe_quality: pipe_ok(pipe) always
rule F reject_bad_inspection: (inspected(pipe.length) and not pipe_ok(pipe)) eventually
rule O pressure_after_change: (not pressure_changed(pipe.pressure) or pipe.pressure > 0) always

fact pipe = Pipe { length = 12, radius = 2, pressure = 5, state = InspectionState.Accepted() }
