module fixture_tube_model

type Tube = { length: rat, r: rat, pressure: int, status: string }

entity tube: Tube

rule O tube_dimensions: (tube.length > 0 and tube.r > 0) always
rule O tube_pressure: tube.pressure > 0 always

fact tube = Tube { length = 12, r = 2, pressure = 5, status = "accepted" }
