module fixture_pipeline_tube_alignment

import "fixture_pipeline_spec.mdl"
import "fixture_tube_model.mdl"

# align kind=field score=0.800 matcher=builtin
rule O alignment_001: fixture_pipeline_spec.pipe.length = fixture_tube_model.tube.length always

# align kind=field score=0.800 matcher=builtin
rule O alignment_002: fixture_pipeline_spec.pipe.pressure = fixture_tube_model.tube.pressure always
