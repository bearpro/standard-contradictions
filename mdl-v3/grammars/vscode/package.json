{
  "name": "mdl-language-support",
  "displayName": "MDL / DDL-LTLf Language Support",
  "description": "Syntax highlighting and language configuration for MDL normative models.",
  "version": "0.1.0",
  "publisher": "mdl",
  "engines": {"vscode": "^1.80.0"},
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [
      {
        "id": "mdl",
        "aliases": ["MDL", "DDL-LTLf MDL"],
        "extensions": [".mdl"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "mdl",
        "scopeName": "source.mdl",
        "path": "./syntaxes/mdl.tmLanguage.json"
      }
    ]
  }
}
