module fixture_pipeline_spec

private type InspectionState = Pending | Accepted | Rejected

type Pipe = { length: rat, radius: rat, pressure: int, state: InspectionState }

val inspection_tags = [1, 2, 3]

private func positive_tags(tags: List<int>) -> bool:
    case tags:
    | List.Cons(tag, rest):
        if tag > 0 then positive_tags(rest) else false
    | List.Empty:
        true

private func is_accepted(state: InspectionState) -> bool:
    case state:
    | Accepted:
        true
    | Pending:
        false
    | Rejected:
        false

private func pipe_ok(pipe: Pipe) -> bool:
    let geometry_ok = pipe.length > 0 and pipe.radius > 0
    let pressure_ok = if pipe.pressure > 0 then true else false
    geometry_ok and pressure_ok and positive_tags(inspection_tags) and is_accepted(pipe.state)

entity pipe: Pipe

event inspected(length: rat)
event pressure_changed(pressure: int)

rule O pipe_geometry = { pipe.length > 0 and pipe.radius > 0 } always
rule O pipe_quality = pipe_ok(pipe) always
rule F reject_bad_inspection = { inspected(pipe.length) and not pipe_ok(pipe) } eventually
rule O pressure_after_change = { pressure_changed(pipe.pressure) implies pipe.pressure > 0 } always

fact pipe = { length = 12, radius = 2, pressure = 5, state = Accepted, }
